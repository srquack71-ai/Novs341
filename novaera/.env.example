# Discord Bot Configuration
DISCORD_TOKEN=seu_token_aqui
PREFIX=!
OWNER_ID=seu_id_aqui

# Status do Bot
BOT_STATUS=online
BOT_ACTIVITY_TYPE=playing
BOT_ACTIVITY=NovaEra | !help

# IA (OpenAI ou g4f)
AI_PROVIDER=g4f
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_FALLBACK_MODEL=gpt-3.5-turbo
FORCE_LOCAL_AI=false

# Banco de dados
DB_PATH=database/database.db

# XP por mensagem
XP_PER_MESSAGE=15
